pkgname='python-uritools'
_module='uritools'
_src_folder='uritools-6.0.1'
pkgver='6.0.1'
pkgrel=1
pkgdesc="URI parsing, classification and composition"
url="None"
depends=('python')
makedepends=('python-build' 'python-installer' 'python-wheel')
license=('unknown')
arch=('any')
source=("https://files.pythonhosted.org/packages/dd/f7/6651d145bedd535a5bdd6dad108329ec1fec89d38ec611f8d98834eb5378/uritools-6.0.1.tar.gz")
sha256sums=('2f9e9cb954e7877232b2c863f724a44a06eb98d9c7ebdd69914876e9487b94f8')

build() {
    cd "${srcdir}/${_src_folder}"
    python -m build --wheel --no-isolation
}

package() {

    cd "${srcdir}/${_src_folder}"
    python -m installer --destdir="${pkgdir}" dist/*.whl
}
